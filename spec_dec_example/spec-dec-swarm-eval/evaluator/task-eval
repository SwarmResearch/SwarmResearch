#!/bin/bash
# Entry point for the spec-dec swarm task.
# Usage:
#   ./task-eval                  # uses tier from $SPEC_DEC_TIER, default 'fast'
#   ./task-eval --tier fast      # explicit tier override
#   ./task-eval --tier medium
#   ./task-eval --tier full
set -e
WRAPPER_DIR="$(cd "$(dirname "$0")" && pwd)"
TASK_DIR="$(cd "$WRAPPER_DIR/.." && pwd)"
HIDDEN_EVAL_DIR="${SPEC_DEC_EVAL_DIR:-$HOME/.spec-dec-eval-hidden/spec-dec-swarm-eval/evaluator}"

TIER="${SPEC_DEC_TIER:-fast}"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --tier) TIER="$2"; shift 2 ;;
        --tier=*) TIER="${1#*=}"; shift ;;
        *) echo "Unknown arg: $1"; exit 1 ;;
    esac
done
export SPEC_DEC_TIER="$TIER"
export SPEC_DEC_TASK_DIR="$TASK_DIR"

if [ ! -f "$HIDDEN_EVAL_DIR/eval.py" ]; then
    echo "Hidden evaluator not found: $HIDDEN_EVAL_DIR/eval.py" >&2
    echo "Set SPEC_DEC_EVAL_DIR to the hidden evaluator directory." >&2
    exit 1
fi

SPEC_DEC_ROOT="${SPEC_DEC_ROOT:-$HOME/spec-dec-work}"
if [ -x "$SPEC_DEC_ROOT/venv/bin/python3" ]; then
    PY="$SPEC_DEC_ROOT/venv/bin/python3"
else
    PY=python3
fi
cd "$HIDDEN_EVAL_DIR"
exec "$PY" -u "$HIDDEN_EVAL_DIR/eval.py"
